<script>
  const allLinks = document.querySelectorAll('a[data-target], .nav-trigger');
  const allSections = document.querySelectorAll('.page-section');
  const navLinksList = document.querySelectorAll('.nav-links a, .mobile-menu a');

  function showSection(targetId) {
    allSections.forEach(sec => sec.classList.remove('active-section'));
    const targetSection = document.getElementById(targetId);
    if(targetSection) targetSection.classList.add('active-section');
    
    navLinksList.forEach(link => {
      if(link.getAttribute('data-target') === targetId) link.classList.add('active');
      else link.classList.remove('active');
    });

    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  allLinks.forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const targetId = link.getAttribute('data-target');
      if(targetId) {
        showSection(targetId);
        mobileMenu.classList.remove('open');
        hamburger.setAttribute('aria-expanded', 'false');
      }
    });
  });

  const hamburger  = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobileMenu');
  hamburger.addEventListener('click', () => {
    const isOpen = mobileMenu.classList.toggle('open');
    hamburger.setAttribute('aria-expanded', isOpen);
  });

  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    navbar.classList.toggle('scrolled', window.scrollY > 30);
  }, { passive: true });

  document.getElementById('formSubmit').addEventListener('click', () => {
    const fname = document.getElementById('fname').value.trim();
    const email = document.getElementById('email').value.trim();
    const message = document.getElementById('message').value.trim();

    if (!fname || !email || !message) {
      alert('Zəhmət olmasa Ad, E-poçt və Mesaj xanalarını doldurun.');
      return;
    }
    ['fname','lname','email','message'].forEach(id => document.getElementById(id).value = '');

    const toast = document.getElementById('toast');
    toast.classList.add('show');
    setTimeout(() => toast.classList.remove('show'), 3500);
  });

  const heroSlider = document.getElementById('heroSlider');
  const heroDots = document.querySelectorAll('.hero-dot');
  let sliderTimer;

  heroSlider.addEventListener('scroll', () => {
    const slideWidth = heroSlider.offsetWidth;
    const activeIndex = Math.round(heroSlider.scrollLeft / slideWidth);
    heroDots.forEach((dot, idx) => dot.classList.toggle('active', idx === activeIndex));
  }, { passive: true });

  function changeSlide(slideIndex) {
    const slideWidth = heroSlider.offsetWidth;
    heroSlider.scrollTo({ left: slideIndex * slideWidth, behavior: 'smooth' });
  }

  function startAutoSlide() {
    sliderTimer = setInterval(() => {
      const slideWidth = heroSlider.offsetWidth;
      const currentIndex = Math.round(heroSlider.scrollLeft / slideWidth);
      let nextSlide = (currentIndex + 1) % 2;
      changeSlide(nextSlide);
    }, 10000);
  }

  heroDots.forEach(dot => {
    dot.addEventListener('click', (e) => {
      const targetIndex = parseInt(e.target.getAttribute('data-slide'));
      changeSlide(targetIndex);
      clearInterval(sliderTimer);
      startAutoSlide();
    });
  });

  startAutoSlide();

  /* ── MOBILE ACCORDION ───────────────────────────── */
  document.querySelectorAll('.mob-group-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const groupId = btn.getAttribute('data-mob-group');
      const sub = document.getElementById('mob-sub-' + groupId);
      const isOpen = sub.classList.contains('open');
      document.querySelectorAll('.mob-sub').forEach(s => s.classList.remove('open'));
      document.querySelectorAll('.mob-group-btn').forEach(b => b.classList.remove('open'));
      if (!isOpen) { sub.classList.add('open'); btn.classList.add('open'); }
    });
  });
</script>

</body>
</html>
